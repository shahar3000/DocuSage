# DocuSage configuration. install.sh writes a real .env from this template plus your
# answers to the three setup prompts. You normally only edit this later to change the
# generation model.

# Port the team opens in the browser (http://<host>:<WEBUI_PORT>)
WEBUI_PORT=3000

# Where models and uploaded manuals are stored on disk (bind-mounted into the containers)
DATA_DIR=./data

# Embedding model (served by Ollama). bge-m3 is a strong default for technical docs.
# Lighter CPU option: nomic-embed-text
EMBEDDING_MODEL=bge-m3

# Generation model (served by Ollama). qwen2.5:7b runs on CPU or a modest GPU.
# More VRAM? Try qwen2.5:14b or qwen2.5:32b for better answers.
GENERATION_MODEL=qwen2.5:7b

# Display name shown in the UI
WEBUI_NAME=DocuSage

# Self-signup. Leave "true" so you can create the first (admin) account; new accounts
# are "pending" until the admin activates them. Set to "false" after the admin exists
# to require the admin to create every account via Admin Panel -> Users -> Add User.
ENABLE_SIGNUP=true
